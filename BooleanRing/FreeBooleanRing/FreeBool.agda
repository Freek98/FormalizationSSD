private module _ {Ôäô : Level} (R : CommRing Ôäô) where
  open CommRingStr (snd R)

  isIdemRing' : Type Ôäô
  isIdemRing' = ÔłÇ (r : ÔčĘ R Ôčę) Ôćĺ r ┬Ě r - r Ôëí 0r
  
  IdemRing'Ôćĺ : isIdemRing' Ôćĺ isIdemRing R
  IdemRing'Ôćĺ p r = equalByDifference (CommRingÔćĺRing R) _ _ (p r)

  IdemRingÔćĺ' : isIdemRing R Ôćĺ isIdemRing'
  IdemRingÔćĺ' p r = r ┬Ě r - r ÔëíÔčĘ cong (╬╗ a Ôćĺ a - r) (p r) Ôčę r - r ÔëíÔčĘ solve! R Ôčę 0r ÔłÄ

module _ {Ôäô : Level} (R : CommRing Ôäô) where
  open CommRingStr ÔŽâ...ÔŽä
  instance
    _ = snd R

  idemFunc : ÔčĘ R Ôčę Ôćĺ ÔčĘ R Ôčę
  idemFunc a = a ┬Ě a - a

  idemIdeal : IdealsIn R
  idemIdeal = genIdeal R idemFunc

  _/Idem : CommRing Ôäô
  _/Idem = R /Im idemFunc

  _/IdemisIdem : isIdemRing _/Idem
  _/IdemisIdem = IdemRing'Ôćĺ _/Idem (SQ.elimProp (╬╗ y Ôćĺ CommRingStr.is-set (str _/Idem) _ _) (zeroOnImage _ _ ))

  forceBA : BooleanRing Ôäô
  forceBA = idemCommRingÔćĺBR _/Idem _/IdemisIdem 

  module _ {Ôäô' : Level} (B : BooleanRing Ôäô') (f : CommRingHom R (BooleanRingÔćĺCommRing B)) where

    instance
      _ = (snd (BooleanRingÔćĺCommRing B))

    open IsCommRingHom (snd f)

    mapsIntoBAsAnnihilatesIdemFunc : (x : ÔčĘ R Ôčę) Ôćĺ
                                     f $cr (idemFunc x) Ôëí 0r
    mapsIntoBAsAnnihilatesIdemFunc x = f $cr ( x ┬Ě x - x)
                                         ÔëíÔčĘ pres+ _ _ Ôčę
                                       f $cr (x ┬Ě x) + f $cr (- x )
                                         ÔëíÔčĘ cong (╬╗ a Ôćĺ _ + a) (pres- _) Ôčę
                                       f $cr (x ┬Ě x) - f $cr x
                                         ÔëíÔčĘ cong (╬╗ a Ôćĺ a - _) (pres┬Ě _ _) Ôčę
                                       f $cr x ┬Ě f $cr x - f $cr x
                                         ÔëíÔčĘ IdemRingÔćĺ' (BooleanRingÔćĺCommRing B) (BooleanRingStr.┬ĚIdem (snd B)) (f $cr x) Ôčę
                                       0r ÔłÄ

opaque 
  freeBA : {Ôäô : Level} Ôćĺ (A : Type Ôäô) Ôćĺ BooleanRing Ôäô
  freeBA A = forceBA (BoolCR [ A ])

opaque
  unfolding freeBA
  generator : {Ôäô : Level} Ôćĺ {A : Type Ôäô} Ôćĺ A Ôćĺ ÔčĘ freeBA A Ôčę
  generator a = quotientHom _ (idemIdeal _) $cr var a

module _ {Ôäô : Level} (A : Type Ôäô) (B : BooleanRing Ôäô) (f : A Ôćĺ ÔčĘ B Ôčę) where
  open IsCommRingHom
  open CommRingStr ÔŽâ...ÔŽä
  instance
    _ = str (BooleanRingÔćĺCommRing B)

  private
    2[A] : CommRing _
    2[A] = BoolCR [ A ]

    2[A]ÔćĺB : (CommRingHom 2[A] (BooleanRingÔćĺCommRing B) )
    2[A]ÔćĺB = TV.inducedHom (BooleanRingÔćĺCommRing B) (BoolBRÔćĺ B) f

    idem : ÔčĘ 2[A] Ôčę Ôćĺ ÔčĘ 2[A] Ôčę
    idem = idemFunc 2[A]
    
    2[A]ÔćĺBRespIdem : (x : ÔčĘ 2[A] Ôčę) Ôćĺ 2[A]ÔćĺB $cr (idem x) Ôëí 0r
    2[A]ÔćĺBRespIdem = mapsIntoBAsAnnihilatesIdemFunc _ B 2[A]ÔćĺB
  
  instance
    _ = str 2[A]
  opaque
    unfolding freeBA
    unfolding IQ.inducedHom
    inducedBAHom : BoolHom (freeBA A) B
    inducedBAHom = IQ.inducedHom 2[A] idem 2[A]ÔćĺB 2[A]ÔćĺBRespIdem 

  opaque
    unfolding freeBA 
    unfolding generator
    unfolding inducedBAHom
    unfolding IQ.inducedHom
    inducedBAHomUnique : (g : BoolHom (freeBA A) B) Ôćĺ
                         ((fst g) Ôłś generator Ôëí f)  Ôćĺ
                         inducedBAHom Ôëí g
    inducedBAHomUnique g agreeOnGens = IQ.inducedHomUnique 2[A] idem 2[A]ÔćĺB 2[A]ÔćĺBRespIdem g 2[A]ÔćĺB=gq where
 
      gÔłśquot : CommRingHom 2[A] (BooleanRingÔćĺCommRing B)
      gÔłśquot = g Ôłścr quotientHom _ _ 
 
      2[A]ÔćĺB=gq : 2[A]ÔćĺB Ôëí gÔłśquot
      2[A]ÔćĺB=gq = TV.inducedHomUnique _ _ f gÔłśquot (BoolBRÔćĺIsUnique B (gÔłśquot Ôłścr constPolynomial BoolCR A)) agreeOnGens


module _ {Ôäô : Level} (A : Type Ôäô) (B : BooleanRing Ôäô) (f : A Ôćĺ ÔčĘ B Ôčę) where
  opaque 
    unfolding generator 
    unfolding inducedBAHom
    unfolding IQ.inducedHom
    evalBAInduce : fst (inducedBAHom A B f) Ôłś generator Ôëí f
    evalBAInduce = TV.evalInduce _ _ f

freeBA-universal-property : {Ôäô : Level} Ôćĺ (A : Type Ôäô) Ôćĺ (B : BooleanRing Ôäô) Ôćĺ 
                            Iso (A Ôćĺ ÔčĘ B Ôčę)
                            (BoolHom (freeBA A) B)
Iso.fun (freeBA-universal-property A B)   = inducedBAHom A B
Iso.inv (freeBA-universal-property A B) f = fst f Ôłś generator
Iso.sec (freeBA-universal-property A B) f = inducedBAHomUnique A B (fst f Ôłś generator) f refl 
Iso.ret (freeBA-universal-property A B)   = evalBAInduce _ _ 

